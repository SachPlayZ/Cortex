# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require&channel_binding=require
# Optional: set false only if your demo Postgres provider needs insecure TLS
DATABASE_SSL_REJECT_UNAUTHORIZED=true
# Bearer token required by POST /api/admin/casper/bootstrap (mandatory in production)
ADMIN_API_TOKEN=

# Casper
CASPER_NETWORK=testnet
CASPER_CHAIN_NAME=casper-test
CASPER_NODE_RPC_URL=http://185.170.112.40:7777/rpc
# Browser-safe RPC used by CSPR.click. Must be HTTPS on hosted deployments.
NEXT_PUBLIC_CASPER_CHAIN_NAME=casper-test
NEXT_PUBLIC_CASPER_NODE_RPC_URL=https://node.testnet.cspr.cloud/rpc

# Contract hashes
INVOICE_REGISTRY_PACKAGE_HASH=hash-5fef146666891b7af8465e6030028f336aa2efe6e0e6d2ba520b5210877642c4
FUNDING_VAULT_PACKAGE_HASH=hash-756757ea8d976f7cdfbae9852fc653f3e0cab00dacd729cc6564943f4584982c
REPAYMENT_ESCROW_PACKAGE_HASH=hash-5ca1cb4499af61e4cec8e51ae105c005e1d11cc9ba5685e09c2c5d4c4dea448f
AGENT_REPUTATION_PACKAGE_HASH=hash-1f17052480f6cc3e639eccfb8b5b8aafa600cda610ddcb977f0f10534863984e

# Relayer - server only
CASPER_ADMIN_PRIVATE_KEY_PATH=/absolute/path/to/admin_secret_key.pem
SETTLEMENT_RELAYER_PUBLIC_KEY=02027164c96d7810a067865fc1dccade50e8d4aa405a40f70ed258dbf6685af663f5
SETTLEMENT_RELAYER_PRIVATE_KEY_PATH=/absolute/path/to/relayer_secret_key.pem
CASPER_RELAYER_PAYMENT_MOTES=2500000000
CASPER_LIFECYCLE_PAYMENT_MOTES=2500000000
AGENT_PUBLIC_KEY=02027164c96d7810a067865fc1dccade50e8d4aa405a40f70ed258dbf6685af663f5
AGENT_PRIVATE_KEY_PATH=
RELAYER_RETRY_TOKEN=
# Optional: auto-deposit vault liquidity (USD cents) during bootstrap
CASPER_BOOTSTRAP_VAULT_LIQUIDITY_CENTS=
# Optional: background sync + relayer retry loop
BACKGROUND_SYNC_INTERVAL_MS=15000
BACKGROUND_RETRY_BATCH_SIZE=25
DISABLE_BACKGROUND_JOBS=false

# CSPR.click wallet UI
NEXT_PUBLIC_CSPRCLICK_APP_ID=csprclick-template
NEXT_PUBLIC_CSPRCLICK_SCRIPT_SRC=https://cdn.cspr.click/ui/v1.12.0/csprclick-client-1.12.0.js

# Dodo Payments
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_WEBHOOK_SECRET=
DODO_PRODUCT_ID=
DODO_ENVIRONMENT=test_mode
DODO_RETURN_URL=http://localhost:3000/checkout/success
DODO_CANCEL_URL=http://localhost:3000/checkout/cancel

# AI/OCR
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

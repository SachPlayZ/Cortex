{
  "name": "cortex",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "pnpm --filter @cortex/web dev",
    "build": "pnpm -r build && cargo +nightly-2026-01-01 check --manifest-path contracts/Cargo.toml",
    "lint": "pnpm -r lint && cargo +nightly-2026-01-01 check --manifest-path contracts/Cargo.toml",
    "typecheck": "pnpm -r typecheck && cargo +nightly-2026-01-01 check --manifest-path contracts/Cargo.toml",
    "test": "pnpm -r test && pnpm test:contracts",
    "test:e2e": "pnpm --filter @cortex/web test:e2e",
    "test:contracts": "cargo +nightly-2026-01-01 test --manifest-path contracts/Cargo.toml",
    "test:agents": "pnpm --filter @cortex/agents test",
    "test:shared": "pnpm --filter @cortex/shared test",
    "sync:casper": "node scripts/run-casper-sync.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "overrides": {
      "postcss": "8.5.15"
    }
  }
}
